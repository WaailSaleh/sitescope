# SiteScope environment configuration
# Copy to .env and fill in values

# Database
DB_PATH=/app/data/sitescope.db

# CORS — set to your public Cloudflare domain in production
# e.g. CORS_ORIGINS=https://sitescope.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60
IP_RATE_LIMIT_MAX=30

TOR_PROXY=socks5://127.0.0.1:9050

# Cloudflare Tunnel token
# Get this from: dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create a tunnel
# Select "Cloudflared" connector, then copy the token shown in the install command
TUNNEL_TOKEN=your-tunnel-token-here
