# ── Secrets & environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
backend/.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/
*.mypy_cache/
*.pytest_cache/
*.ruff_cache/
.coverage
htmlcov/

# ── Node / npm ────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.vite/
frontend/dist/
frontend/build/

# ── Runtime data (SQLite DB, logs) ────────────────────────────────────────────
data/*.db
data/*.db-wal
data/*.db-shm
data/*.log

# Keep the data/ directory itself tracked (so git knows it exists)
!data/.gitkeep

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfiles are intentionally committed)

