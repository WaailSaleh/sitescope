# =============================================================================
# SiteScope — GitHub Variables & Secrets
# =============================================================================
# Add each value to your GitHub repo:
#   Settings → Secrets and variables → Actions
# =============================================================================

# ---- VARIABLES (Settings → Variables → Actions) ---------------------------

# Full subdomain for this app (must match Cloudflare Tunnel public hostname)
SUBDOMAIN=sitescope.jidka.org


# ---- SECRETS (Settings → Secrets → Actions) --------------------------------

# GitHub PAT for pushing/pulling from ghcr.io
# Create at: github.com/settings/tokens → Generate new token (classic)
# Required scopes: write:packages, read:packages
GHCR_TOKEN=ghp_your-github-pat
